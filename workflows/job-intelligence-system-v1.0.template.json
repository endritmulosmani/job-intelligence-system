                  {
                      "parameters":  {
                                         "jsCode":  "function cleanText(value) {\n  return String(value || \u0027\u0027)\n    .replace(/\u0026/g, \u0027and\u0027)\n    .replace(/\u003c/g, \u0027\u0027)\n    .replace(/\u003e/g, \u0027\u0027)\n    .replace(/_/g, \u0027-\u0027)\n    .replace(/\\*/g, \u0027\u0027)\n    .replace(/\\[/g, \u0027\u0027)\n    .replace(/\\]/g, \u0027\u0027)\n    .replace(/\\(/g, \u0027\u0027)\n    .replace(/\\)/g, \u0027\u0027)\n    .replace(/`/g, \u0027\u0027)\n    .replace(/\"/g, \u0027\u0027)\n    .replace(/\u0027/g, \u0027\u0027)\n    .replace(/\\s+/g, \u0027 \u0027)\n    .trim();\n}\n\nfunction cleanUrl(value) {\n  return String(value || \u0027\u0027)\n    .replace(/\\s+/g, \u0027\u0027)\n    .trim();\n}\n\nfunction normalizeUrl(value) {\n  return cleanUrl(value).split(\u0027?\u0027)[0];\n}\n\nconst aggregated = $json.data || [];\nconst account = \u0027YOUR_EMAIL_ACCOUNT\u0027;\nconst maxLength = 3500;\n\nconst titleBlacklist = [\n  \u0027unsubscribe\u0027,\n  \u0027privacy\u0027,\n  \u0027datenschutz\u0027,\n  \u0027legal\u0027,\n  \u0027facebook\u0027,\n  \u0027twitter\u0027,\n  \u0027instagram\u0027,\n  \u0027glassdoor\u0027,\n  \u0027forbes\u0027,\n  \u0027sign in\u0027,\n  \u0027login\u0027,\n  \u0027update your profile\u0027,\n  \u0027view relevant jobs\u0027,\n  \u0027manage notifications\u0027,\n  \u0027preferences\u0027,\n  \u0027finance\u0027,\n  \u0027controlling\u0027,\n  \u0027accounting\u0027,\n  \u0027sales\u0027,\n  \u0027marketing\u0027,\n  \u0027human resources\u0027,\n  \u0027hr business\u0027,\n  \u0027procurement\u0027,\n  \u0027supply chain\u0027\n];\n\nconst linkBlacklist = [\n  \u0027unsubscribe\u0027,\n  \u0027privacy\u0027,\n  \u0027datenschutz\u0027,\n  \u0027legal\u0027,\n  \u0027facebook\u0027,\n  \u0027twitter\u0027,\n  \u0027instagram\u0027,\n  \u0027glassdoor\u0027,\n  \u0027forbes\u0027,\n  \u0027careerhub/me\u0027,\n  \u0027login\u0027\n];\n\nconst whitelist = [\n  \u0027werkstudent\u0027,\n  \u0027working student\u0027,\n  \u0027internship\u0027,\n  \u0027praktikum\u0027,\n  \u0027student\u0027,\n  \u0027engineer\u0027,\n  \u0027engineering\u0027,\n  \u0027developer\u0027,\n  \u0027electronics\u0027,\n  \u0027elektronik\u0027,\n  \u0027elektrotechnik\u0027,\n  \u0027automation\u0027,\n  \u0027automatisierung\u0027,\n  \u0027embedded\u0027,\n  \u0027firmware\u0027,\n  \u0027software\u0027,\n  \u0027hardware\u0027,\n  \u0027systems\u0027,\n  \u0027systeme\u0027,\n  \u0027application\u0027,\n  \u0027testing\u0027,\n  \u0027validation\u0027,\n  \u0027python\u0027,\n  \u0027c++\u0027,\n  \u0027iot\u0027,\n  \u0027microcontroller\u0027,\n  \u0027semiconductor\u0027,\n  \u0027halbleiter\u0027,\n  \u0027standard cells\u0027,\n  \u0027datenanalyse\u0027,\n  \u0027qualitätsmanagement\u0027\n];\n\nfunction isRelevant(title, link) {\n  const t = title.toLowerCase();\n  const l = link.toLowerCase();\n\n  if (!title || !link) return false;\n  if (!link.startsWith(\u0027http\u0027)) return false;\n  if (title.length \u003c 10) return false;\n\n  if (titleBlacklist.some(b =\u003e t.includes(b))) return false;\n  if (linkBlacklist.some(b =\u003e l.includes(b))) return false;\n  if (!whitelist.some(w =\u003e t.includes(w))) return false;\n\n  return true;\n}\n\nconst blocks = [];\nconst globalSeen = new Set();\n\nfor (const email of aggregated) {\n  const source = cleanText(email.from?.value?.[0]?.name || \u0027Unknown\u0027);\n  const sender = cleanText(email.from?.value?.[0]?.address || \u0027\u0027);\n  const jobs = email.jobs || [];\n  const links = email.links || [];\n\n  const jobLines = [];\n\n  for (let i = 0; i \u003c jobs.length; i++) {\n    const title = cleanText(jobs[i]);\n    const link = normalizeUrl(links[i]);\n\n    if (!isRelevant(title, link)) continue;\n\n    const key = `${title.toLowerCase()}|${link.toLowerCase()}`;\n    if (globalSeen.has(key)) continue;\n    globalSeen.add(key);\n\n    jobLines.push(`📌 ${title}\\n${link}`);\n  }\n\n  if (jobLines.length === 0) continue;\n\n  const block = `━━━━━━━━━━━━━━\n🏢 ${source}\n\n${jobLines.join(\u0027\\n\\n\u0027)}\n\n📧 ${sender}`;\n\n  blocks.push(block);\n}\n\nif (blocks.length === 0) {\n  return [];\n}\n\nconst messages = [];\nlet current = `📬 ACCOUNT: ${account}\\n\\n`;\n\nfor (const block of blocks) {\n  const candidate = current + block + \u0027\\n\\n\u0027;\n\n  if (candidate.length \u003e maxLength) {\n    if (current.trim() !== `📬 ACCOUNT: ${account}`) {\n      messages.push(current.trim());\n    }\n    current = `📬 ACCOUNT: ${account}\\n\\n${block}\\n\\n`;\n  } else {\n    current = candidate;\n  }\n}\n\nif (current.trim().length \u003e 0) {\n  messages.push(current.trim());\n}\n\nreturn messages.map((message, index) =\u003e ({\n  json: {\n    message: `Part ${index + 1}/${messages.length}\\n\\n${message}`\n  }\n}));"
                                     },
